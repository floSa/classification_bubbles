# Infra Configuration
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=password
TIMESCALE_DB=bubble_db
TIMESCALE_PORT=5433

MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=password
MONGO_PORT=27018

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# === Options de simulation (optionnel) ===
# Fraction des chunks dont le label stocké en DB sera volontairement faux,
# pour rendre le problème de classification plus réaliste (typique : 0.03–0.05).
# 0.0 = pas de bruit de label (défaut).
LABEL_NOISE_RATE=0.0

# === Options service acquisition (optionnel) ===
# FORCE_CLEAN=true purge TimescaleDB + supprime le modèle au démarrage de
# l'acquisition. À utiliser uniquement pour repartir d'un état totalement vierge.
# FORCE_CLEAN=false
